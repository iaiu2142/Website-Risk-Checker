{
  "manifest_version": 3,
  "name": "AI Security Scanner",
  "version": "1.0",
  "description": "Detects malicious website content using ML model",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
  "<all_urls>",
  "http://127.0.0.1:5000/*"
],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}